or 
nano build.gradle  :

plugins {
    id 'java-library'
    id 'maven-publish'
    id 'application'
}

application {
    mainClass = 'com.mycompany.app.App'
}

jar {
    manifest {
        attributes(
            'Main-Class': 'com.mycompany.app.App'  // Ensure this matches your actual main class
        )
    }
}


//7. 
gradle build


//8. how to check outcome

java -jar build/libs/my-app-1.0-SNAPSHOT.jar


//9.how toclean build

gradle clean build

//10. how to check maven build output

java -jar target/*.jar

